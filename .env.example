# =============================================================================
# Enterprise Face Search Platform — Environment Configuration
# Copy to .env and fill in values before running `make dev`
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=photogenic
POSTGRES_USER=photogenic
POSTGRES_PASSWORD=changeme_pg_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- MinIO (S3-compatible object store) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_password
MINIO_BUCKET=photogenic
MINIO_USE_SSL=false

# --- Environment ---
# development = allow missing-token fallback + /v1/auth/dev-token
# production  = require Bearer JWT (fail closed)
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT / OIDC ---
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
# For production OIDC:
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=photogenic
# OIDC_AUDIENCE=photogenic-api

# --- ML Inference Service ---
ML_INFERENCE_URL=http://ml-inference:8001
ML_MODEL_PACK=buffalo_l
ML_DET_SIZE=640
ML_QUALITY_FLOOR=0.3
ML_MIN_FACE_PX=20
ML_DET_SCORE_FLOOR=0.5

# --- Identity Service ---
IDENTITY_SERVICE_URL=http://identity:8002

# --- Retrieval Service ---
RETRIEVAL_SERVICE_URL=http://retrieval:8003

# --- API Gateway ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Celery Workers ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
