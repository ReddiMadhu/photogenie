{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photogenic.local/schemas/policy/retention_rule/v1",
  "title": "RetentionRule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rule_id",
    "artifact_type",
    "retain_days",
    "destruction_method",
    "legal_hold_suspends_destruction"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "rule_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,64}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "source_image_copy",
        "face_crop",
        "face_embedding",
        "query_image",
        "audit_event",
        "evaluation_set"
      ]
    },
    "retain_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3650
    },
    "max_days_from_last_interaction": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3650
    },
    "destruction_method": {
      "type": "string",
      "enum": [
        "soft_tombstone_then_purge",
        "cryptographic_erase",
        "object_delete",
        "backup_ttl_expire"
      ]
    },
    "legal_hold_suspends_destruction": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  }
}
