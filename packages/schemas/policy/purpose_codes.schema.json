{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photogenic.local/schemas/policy/purpose_codes/v1",
  "title": "PurposeCodes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "purposes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "description", "risk_tier", "requires_break_glass", "allowed_environments"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,64}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "risk_tier": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "requires_break_glass": {
            "type": "boolean"
          },
          "allowed_environments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["development", "test", "staging", "production"]
            }
          },
          "prohibited": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
