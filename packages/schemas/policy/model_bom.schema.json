{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photogenic.local/schemas/policy/model_bom/v1",
  "title": "ModelBillOfMaterials",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_id",
    "capability",
    "algorithm",
    "version",
    "filename",
    "sha256",
    "format",
    "commercial_use_allowed",
    "owner_team",
    "approved_by",
    "approved_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "model_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,128}$"
    },
    "capability": {
      "type": "string",
      "enum": ["detection", "embedding", "fiqa", "alignment_support", "other"]
    },
    "algorithm": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "format": {
      "type": "string",
      "enum": ["onnx", "tensorrt", "pytorch", "other"]
    },
    "license_spdx": {
      "type": "string"
    },
    "license_name": {
      "type": "string"
    },
    "commercial_use_allowed": {
      "type": "boolean"
    },
    "license_evidence_uri": {
      "type": "string",
      "format": "uri"
    },
    "training_data_summary": {
      "type": "string"
    },
    "training_data_restrictions": {
      "type": "string"
    },
    "owner_team": {
      "type": "string"
    },
    "approved_by": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "deployment_restrictions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evaluation_report_uri": {
      "type": "string",
      "format": "uri"
    },
    "signature": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["cosign", "internal_hsm", "none"]
        },
        "value": { "type": "string" }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "commercial_use_allowed": { "const": true } }
      },
      "then": {
        "required": ["license_evidence_uri"]
      }
    }
  ]
}
