{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photogenic.local/schemas/policy/jurisdiction_profile/v1",
  "title": "JurisdictionProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "jurisdiction_id",
    "display_name",
    "biometric_notice_required",
    "written_release_required",
    "max_retention_days",
    "ingestion_enabled",
    "embedding_enabled",
    "search_enabled",
    "export_enabled",
    "identity_naming_enabled",
    "minors_processing_allowed",
    "allowed_purpose_codes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,64}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "biometric_notice_required": {
      "type": "boolean"
    },
    "written_release_required": {
      "type": "boolean"
    },
    "explicit_consent_preferred": {
      "type": "boolean",
      "default": false
    },
    "max_retention_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3650
    },
    "ingestion_enabled": {
      "type": "boolean"
    },
    "embedding_enabled": {
      "type": "boolean"
    },
    "search_enabled": {
      "type": "boolean"
    },
    "export_enabled": {
      "type": "boolean"
    },
    "identity_naming_enabled": {
      "type": "boolean"
    },
    "query_image_persist_enabled": {
      "type": "boolean",
      "default": true
    },
    "minors_processing_allowed": {
      "type": "boolean"
    },
    "allowed_purpose_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{2,64}$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
