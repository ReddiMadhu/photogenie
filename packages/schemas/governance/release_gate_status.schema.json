{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photogenic.local/schemas/governance/release_gate_status/v1",
  "title": "ReleaseGateStatus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "target_environment",
    "gates",
    "overall_status",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "target_environment": {
      "type": "string",
      "enum": ["staging", "production"]
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "title", "mandatory", "status"],
        "properties": {
          "gate_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,64}$"
          },
          "title": { "type": "string" },
          "mandatory": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_review", "approved", "rejected", "waived"]
          },
          "owner_role": { "type": "string" },
          "evidence_uri": { "type": "string" },
          "approved_by": { "type": "string" },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": { "type": "string" }
        }
      }
    },
    "overall_status": {
      "type": "string",
      "enum": ["blocked", "ready", "rejected"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  }
}
